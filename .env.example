# EKI PRO runtime configuration
# Do not commit real production secrets into this file.

# CoinGecko Demo API key. Server-side only.
CG_API_KEY="CG-REPLACE_ME"

# Neon Postgres connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Portfolio strategy controls.
STRATEGY_MODE="ON"
BETTING_VAULT_PCT="0"
CLV_ROLLING_50="0"
BETTING_VELOCITY="0"

# Public deployment URL, used by GitHub Actions CRON.
APP_URL="https://eki-pro-monolith.vercel.app"
