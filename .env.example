# EKI PRO runtime configuration
# Do not commit real production secrets into this file.

# CoinGecko Demo API key.
# Required by engine/update_kpis.ts as requested.
NEXT_PUBLIC_CG_API_KEY="CG-REPLACE_ME"

# Supabase REST API access for server-side KPI persistence.
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY"

# Portfolio strategy controls.
STRATEGY_MODE="ON"
CORE_RATIO="0.90"
MOONSHOT_RATIO="0.10"
BETTING_VAULT_RATIO="0"

# Optional app metadata.
APP_URL="https://YOUR_VERCEL_PROJECT.vercel.app"

# Legacy / optional AI Studio variables retained only if the app still uses them.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
